# LLM provider: ollama | dummy
# - ollama: valodi nyilt LLM (llama3.1:8b), function calling tamogatas
# - dummy:  determinisztikus stub valaszok, out-of-the-box fut LLM nelkul
LLM_PROVIDER=ollama

# Ollama beallitasok (csak ha LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Embedding modell (sentence-transformers, lokalis, multilingual)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ChromaDB perzisztens tarolas
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=documents

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Agentic loop vedelem
MAX_ITERATIONS=8
MAX_VALIDATOR_RETRIES=2

# Streamlit
STREAMLIT_PORT=8501
