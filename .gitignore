__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtuális környezet (NEM hordozható mappa-másolással — minden új helyen
# `python3.12 -m venv .venv` paranccsal újra létre kell hozni)
.venv/
venv/
env/
ENV/

# Disztribúció / build
build/
dist/
*.egg-info/
*.egg
.eggs/

